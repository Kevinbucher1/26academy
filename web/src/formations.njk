---
layout: base.njk
title: "Toutes nos formations"
permalink: /formations/
---
<div class="container mx-auto px-6 py-12">
    <h1 class="text-4xl font-bold mb-8">Toutes nos formations</h1>
    <div class="grid md:grid-cols-3 gap-6">
        {% for formation in formations %}
            <a href="/formations/{{ formation.slug.current }}/" class="border p-6 rounded-lg hover:shadow-lg transition-shadow">
                <h2 class="text-2xl font-bold text-brand-dark">{{ formation.title }}</h2>
                <p class="text-gray-600 mt-2">Catégorie : {{ formation.category }}</p>
            </a>
        {% endfor %}
    </div>
</div>