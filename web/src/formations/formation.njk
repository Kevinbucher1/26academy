---
pagination:
  data: formations
  size: 1
  alias: formation
permalink: "/formations/{{ formation.slug.current }}/"
layout: base.njk
# SEO : On passe le titre et la description au layout
title: "{{ formation.seo.metaTitle or formation.title }}"
metaDescription: "{{ formation.seo.metaDescription }}"
---

<section class="relative h-[70vh] min-h-[500px] flex items-center text-white overflow-hidden">
    <div class="absolute inset-0 z-0">
        {% if formation.hero_section.video_url %}
            <video src="{{ formation.hero_section.video_url }}" autoplay loop muted playsinline class="w-full h-full object-cover"></video>
        {% endif %}
        <div class="absolute inset-0 bg-gray-900/60"></div>
    </div>
    <div class="container mx-auto px-6 z-10">
        <div class="max-w-2xl">
            <h1 class="text-4xl md:text-6xl font-extrabold leading-tight tracking-tight">
                Devenez <span class="text-brand">{{ formation.title }}</span>.
            </h1>
            <p class="mt-4 text-lg md:text-xl text-gray-200">{{ formation.hero_section.subtitle }}</p>
            <a href="#" class="mt-8 inline-block btn-primary">{{ formation.hero_section.cta_button_text }}</a>
        </div>
    </div>
</section>

{% if formation.features_section %}
<section class="py-20 bg-white text-gray-800">
    <div class="container mx-auto px-6">
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
            {% for feature in formation.features_section %}
            <div class="bg-gray-50 border border-gray-200 p-6 rounded-xl text-center transition-transform hover:-translate-y-2">
                <i data-lucide="{{ feature.icon }}" class="mx-auto h-10 w-10 text-brand"></i>
                <h3 class="font-bold text-lg mt-4 text-gray-900">{{ feature.title }}</h3>
                <p class="text-gray-600 text-sm mt-2">{{ feature.description }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}


{% if formation.audience_section %}
<section class="py-20 bg-white text-gray-800">
    <div class="container mx-auto px-6 text-center">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">{{ formation.audience_section.title }}</h2>
        <p class="text-gray-600 mb-12 max-w-2xl mx-auto">{{ formation.audience_section.subtitle }}</p>
        <div class="grid md:grid-cols-3 gap-8">
            {% for card in formation.audience_section.audience_cards %}
            <div class="bg-white rounded-2xl overflow-hidden group border border-gray-200 hover:shadow-lg transition-shadow">
                <img src="{{ card.image.asset._ref | sanityImageUrl }}" alt="{{ card.image.alt or card.title }}" class="w-full h-56 object-cover group-hover:scale-105 transition-transform duration-300">
                <div class="p-6 text-left">
                    <h3 class="font-bold text-xl text-gray-900">{{ card.title }}</h3>
                    <p class="text-gray-600 mt-2">{{ card.description }}</p>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{% if formation.program_modules %}
<section class="py-20 bg-white text-gray-800">
    <div class="container mx-auto px-6">
        <h2 class="text-3xl font-bold text-center mb-12">Découvrez le programme</h2>
        <div class="max-w-3xl mx-auto space-y-4">
            {% for module in formation.program_modules %}
            <div class="accordion-item bg-gray-50 rounded-lg border border-gray-200">
                <button class="accordion-header w-full p-5 flex justify-between items-center text-left text-lg font-semibold">
                    <span>{{ module.title }}</span>
                    <i data-lucide="chevron-down" class="icon"></i>
                </button>
                <div class="accordion-content px-5">
                    <p class="pb-5 text-gray-600">{{ module.details }}</p>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{% if formation.pricing_section %}
<section class="py-20 bg-white text-gray-800">
    <div class="container mx-auto px-6 text-center">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">{{ formation.pricing_section.title }}</h2>
        <p class="text-gray-600 mb-12 max-w-2xl mx-auto">{{ formation.pricing_section.subtitle }}</p>
        <div class="grid lg:grid-cols-3 gap-8 max-w-6xl mx-auto items-stretch">
            {% for card in formation.pricing_section.pricing_cards %}
            <div class="p-8 rounded-2xl flex flex-col text-left {% if card.is_featured %}bg-brand text-white transform md:scale-105{% else %}bg-white border border-gray-200{% endif %}">
                <h3 class="text-xl font-bold {% if not card.is_featured %}text-gray-900{% endif %}">{{ card.title }}</h3>
                <p class="mt-2 flex-grow {% if card.is_featured %}opacity-90{% else %}text-gray-600{% endif %}">{{ card.description }}</p>
                <div class="my-6">
                    <span class="text-4xl font-extrabold {% if not card.is_featured %}text-gray-900{% endif %}">{{ card.price }}</span>
                    <span class="{% if card.is_featured %}opacity-80{% else %}text-gray-500{% endif %}">{{ card.price_details }}</span>
                </div>
                <a href="#" class="w-full text-center mt-auto py-3 rounded-full transition-colors {% if card.is_featured %}bg-white text-brand font-bold{% else %}bg-gray-100 text-gray-800 font-semibold hover:bg-gray-200{% endif %}">{{ card.cta_text }}</a>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}