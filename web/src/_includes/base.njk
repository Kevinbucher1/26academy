{# web/src/_includes/base.njk #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title or "26 Academy - Votre avenir commence ici" }}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root {
            --brand-primary: #6A49F2;
            --brand-secondary: #7F65F5;
            --brand-dark: #2c2a52;
        }
        body { font-family: 'Inter', sans-serif; background-color: #ffffff; }
        .gradient-bg { background-color: var(--brand-secondary); background-image: linear-gradient(135deg, var(--brand-secondary) 0%, var(--brand-primary) 100%); }
        .btn { border-radius: 8px; padding: 12px 24px; font-weight: 600; transition: all 0.3s ease; display: inline-flex; align-items: center; justify-content: center; }
        .btn-primary { background-color: var(--brand-primary); color: white; }
        .btn-primary:hover { background-color: var(--brand-dark); }
        .btn-secondary { background-color: #F3F4F6; color: var(--brand-dark); }
        .btn-secondary:hover { background-color: #E5E7EB; }
        .btn-outline { background-color: white; color: var(--brand-primary); border: 1px solid #E5E7EB; }
        .btn-outline:hover { background-color: #F9FAFB; }
    </style>
</head>
<body class="text-gray-800">

    {% include "header.njk" %}

    <main>
        {# Le contenu spécifique de chaque page sera injecté ici #}
        {{ content | safe }}
    </main>

    {% include "footer.njk" %}

</body>
</html>